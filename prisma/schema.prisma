generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER_ADMIN
  DIRECTOR
  ADMISSION_OFFICIAL
  CENTER_MANAGER
}

enum RegistrationStatus {
  NEW
  VIEWED
  APPROVED
  UNAPPROVED
  NEEDS_FURTHER_REVIEW
  REJECTED
}

model AdminUser {
  id                  String          @id @default(cuid())
  name                String
  email               String          @unique
  passwordHash        String
  role                AdminRole
  center              String?
  active              Boolean         @default(true)
  forcePasswordChange Boolean         @default(false)
  lastLoginAt         DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  approvals           Registration[]  @relation("RegistrationApprover")
  reviews             Registration[]  @relation("RegistrationReviewer")
  auditActions        AdminAuditLog[] @relation("AuditActor")
  auditTargets        AdminAuditLog[] @relation("AuditTarget")
}

model Registration {
  id                  String                     @id @default(cuid())
  fullName            String
  email               String
  phone               String
  course              String
  category            String
  level               String
  center              String
  session             String
  hostel              String
  action              String
  receiveUpdates      Boolean                    @default(true)
  status              RegistrationStatus         @default(NEW)
  verificationAnswers Json
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  approvedAt          DateTime?
  approvedById        String?
  approvedBy          AdminUser?                 @relation("RegistrationApprover", fields: [approvedById], references: [id])
  reviewedAt          DateTime?
  reviewedById        String?
  reviewedBy          AdminUser?                 @relation("RegistrationReviewer", fields: [reviewedById], references: [id])
  reviewedRole        String?
  reviewNote          String?
  reviewReason        String?
  reviewReasonOther   String?
  wasEdited           Boolean                    @default(false)
  editCount           Int                        @default(0)
  editedAt            DateTime?
  originalSubmittedAt DateTime?
  editedAfterDecision Boolean                    @default(false)
  files               RegistrationFile[]
  notifications       RegistrationNotification[]

  @@index([center])
  @@index([status])
  @@index([createdAt])
  @@index([wasEdited])
  @@index([editedAfterDecision])
}

model RegistrationFile {
  id             String       @id @default(cuid())
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  fileName       String
  originalName   String
  mimeType       String
  size           Int
  storagePath    String
  createdAt      DateTime     @default(now())

  @@index([registrationId])
}

model RegistrationNotification {
  id             String       @id @default(cuid())
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  targetRole     AdminRole
  targetCenter   String?
  seen           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([targetRole, seen])
  @@index([targetCenter, seen])
}

model EmailVerificationCode {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

model AdminAuditLog {
  id           String     @id @default(cuid())
  actorId      String?
  actor        AdminUser? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action       String
  targetUserId String?
  targetUser   AdminUser? @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  ipAddress    String?
  createdAt    DateTime   @default(now())

  @@index([actorId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
}
